<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Photo Gallery</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

<h1>Nature Gallery</h1>

<div id="image">
    Hover over an image below to display here.
</div>

<img src="beach.jpg" alt="Beautiful Beach"
     onmouseover="upDate(this)" 
     onmouseout="undo()">

<img src="mountain.jpg" alt="Majestic Mountain"
     onmouseover="upDate(this)" 
     onmouseout="undo()">

<img src="galaxy.jpg" alt="Stunning Galaxy"
     onmouseover="upDate(this)" 
     onmouseout="undo()">

<script src="script.js"></script>

</body>
</html>
